# =====================================================
# SillyTavern Next 环境变量示例
# 复制此文件为 .env.local（本地开发）或 .env（Docker）后填写
# =====================================================

# === 必填 ===

# NextAuth 签名密钥
# 生成强随机串：openssl rand -hex 32
# 留空会导致 production 模式启动失败
AUTH_SECRET=

# 站点访问 URL（用于 OAuth 回调，本地开发不变即可）
AUTH_URL=http://localhost:3000


# === 可选：AI 提供商默认 Key ===
# 推荐登录后在 UI 的 Settings → API Connections 中配置（按用户隔离存储于 DB）。
# 此处填写仅作为该用户未配置时的回退默认值，留空即可。

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=


# === 数据库 ===
# 默认 SQLite，无需修改。Docker 部署时被 docker-compose.yml 覆盖为 /app/data/sillytavern.db
DATABASE_URL=./data/sillytavern.db
